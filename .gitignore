# Obsidian vault metadata (user-specific)
.obsidian/workspace*
.obsidian/cache
.obsidian/graph.json
.obsidian/app.json
.obsidian/appearance.json
.obsidian/core-plugins*.json
.obsidian/hotkeys.json

# OS junk
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# Editor junk
.vscode/
.idea/
*.iml

# Temp files
*.tmp
*.bak
*.orig

# Secrets (defensive — no API tokens should ever be committed)
.env
.env.*
*.key
*.pem
credentials.json
secrets.json
